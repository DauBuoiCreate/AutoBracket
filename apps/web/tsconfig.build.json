{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "incremental": true,
    "noEmit": false,
    "outDir": "dist/types",
    "rootDir": ".",
    "tsBuildInfoFile": "dist/types/.tsbuildinfo"
  },
  "include": ["next-env.d.ts", "next.config.ts", "scripts/**/*.ts", "src/**/*.ts", "src/**/*.tsx"],
  "references": [
    { "path": "../../packages/config/tsconfig.build.json" },
    { "path": "../../packages/contracts/tsconfig.build.json" },
    { "path": "../../packages/db/tsconfig.build.json" },
    { "path": "../../packages/ui/tsconfig.build.json" }
  ]
}
