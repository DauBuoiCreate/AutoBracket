{
  "name": "@autobracket/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsx scripts/preflight.ts && next build && node scripts/prepare-standalone.mjs",
    "dev": "tsx scripts/preflight.ts && next dev",
    "preflight": "tsx scripts/preflight.ts",
    "start": "tsx scripts/start-standalone.ts",
    "typecheck": "tsx scripts/preflight.ts && next typegen && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@autobracket/config": "workspace:*",
    "@autobracket/contracts": "workspace:*",
    "@autobracket/db": "workspace:*",
    "@autobracket/ui": "workspace:*",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "redis": "6.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "esbuild": "0.28.1",
    "postcss": "8.5.18",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.1"
  }
}
