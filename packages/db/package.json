{
  "name": "@autobracket/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate --config prisma.config.ts && tsc -p tsconfig.build.json",
    "db:generate": "prisma generate --config prisma.config.ts",
    "db:migrate": "prisma migrate deploy --config prisma.config.ts",
    "db:migrate:dev": "prisma migrate dev --config prisma.config.ts",
    "db:seed": "prisma db seed --config prisma.config.ts",
    "typecheck": "prisma generate --config prisma.config.ts && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@autobracket/contracts": "workspace:*",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "prisma": "7.8.0",
    "tsx": "4.23.1"
  }
}
