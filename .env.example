# Runtime defaults (non-secret)
NODE_ENV=development
APP_URL=http://localhost:3000
PUBLIC_URL=http://localhost:3000
PORT=3000
LOG_LEVEL=info
RELEASE_VERSION=development
REALTIME_PORT=3001
WORKER_HEALTH_PORT=3002

# P0-02 data services
POSTGRES_DB=autobracket
POSTGRES_USER=autobracket
POSTGRES_PASSWORD=autobracket
POSTGRES_PORT=55432
REDIS_PORT=57379
DATABASE_URL=postgresql://autobracket:autobracket@localhost:55432/autobracket
REDIS_URL=redis://localhost:57379

# Future auth, storage, email, billing and observability adapters.
# Leave secrets empty locally until the phase that introduces each adapter.
SESSION_SECRET=
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
EMAIL_FROM=
EMAIL_PROVIDER_TOKEN=
BILLING_SECRET_KEY=
BILLING_WEBHOOK_SECRET=
ERROR_TRACKING_DSN=
