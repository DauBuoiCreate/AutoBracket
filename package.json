{
  "name": "autobracket",
  "version": "0.0.0",
  "private": true,
  "description": "Nền tảng tổ chức và vận hành giải đấu thể thao.",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": "24.14.1",
    "pnpm": "11.12.0"
  },
  "scripts": {
    "preinstall": "node ./scripts/require-pnpm.mjs",
    "dev": "corepack pnpm -r --sort --filter @autobracket/config --filter @autobracket/contracts --filter @autobracket/db --filter @autobracket/domain --filter @autobracket/testkit --filter @autobracket/ui --if-present run build && corepack pnpm -r --parallel --filter @autobracket/web --filter @autobracket/realtime --filter @autobracket/worker --if-present run dev",
    "build": "corepack pnpm -r --sort --if-present run build",
    "audit:prod": "corepack pnpm audit --prod --audit-level=moderate",
    "db:generate": "corepack pnpm --filter @autobracket/db db:generate",
    "db:migrate": "corepack pnpm --filter @autobracket/db db:migrate",
    "db:migrate:dev": "corepack pnpm --filter @autobracket/db db:migrate:dev",
    "db:seed": "corepack pnpm --filter @autobracket/db db:seed",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "corepack pnpm -r --sort --if-present run typecheck",
    "test": "corepack pnpm test:unit",
    "test:e2e": "node ./scripts/run-web-e2e.mjs",
    "test:engine": "vitest run packages/domain",
    "test:unit": "vitest run",
    "guard:plan": "node ./scripts/guard-plan.mjs",
    "infra:down": "docker compose --project-directory . -f infra/docker/compose.dev.yml down",
    "infra:logs": "docker compose --project-directory . -f infra/docker/compose.dev.yml logs --follow",
    "infra:ps": "docker compose --project-directory . -f infra/docker/compose.dev.yml ps",
    "infra:up": "docker compose --project-directory . -f infra/docker/compose.dev.yml up --detach --wait",
    "staging:clean": "docker compose --project-directory . --env-file .env.staging -f infra/docker/compose.staging.yml down --volumes --remove-orphans",
    "staging:down": "docker compose --project-directory . --env-file .env.staging -f infra/docker/compose.staging.yml down",
    "staging:logs": "docker compose --project-directory . --env-file .env.staging -f infra/docker/compose.staging.yml logs --follow",
    "staging:ps": "docker compose --project-directory . --env-file .env.staging -f infra/docker/compose.staging.yml ps",
    "staging:smoke": "corepack pnpm staging:validate && node --env-file=.env.staging ./scripts/smoke-staging.mjs",
    "staging:up": "corepack pnpm staging:validate && docker compose --project-directory . --env-file .env.staging -f infra/docker/compose.staging.yml up --build --detach --wait",
    "staging:validate": "node --env-file=.env.staging ./scripts/validate-staging-env.mjs",
    "test:integration": "corepack pnpm --filter @autobracket/db build && vitest run --config vitest.integration.config.ts",
    "verify": "corepack pnpm guard:plan && corepack pnpm verify:ci-negative && corepack pnpm format:check && corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test:unit && corepack pnpm test:integration && corepack pnpm build && corepack pnpm verify:runtime-startup",
    "verify:ci-negative": "node ./scripts/verify-ci-negative.mjs",
    "verify:clean": "node ./scripts/verify-clean-copy.mjs",
    "verify:clean-setup": "node ./scripts/verify-clean-setup.mjs",
    "verify:runtime-startup": "node ./scripts/verify-runtime-startup.mjs"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
