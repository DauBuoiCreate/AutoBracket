# Local staging skeleton only. Production must use managed secrets.
POSTGRES_DB=autobracket
POSTGRES_USER=autobracket
POSTGRES_PASSWORD=autobracket-staging-local
STAGING_DATABASE_URL=postgresql://autobracket:autobracket-staging-local@postgres:5432/autobracket
RELEASE_VERSION=p0-staging-local
LOG_LEVEL=info
STAGING_PUBLIC_URL=http://localhost:3100
STAGING_WEB_PORT=3100
STAGING_REALTIME_PORT=3101
STAGING_WORKER_PORT=3102
